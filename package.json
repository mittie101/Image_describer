{
  "name": "image-description-generator",
  "version": "2.2.0",
  "description": "AI-powered image description generator for Midjourney prompts",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint main.js preload.js src/app.js src/setup.js",
    "lint:fix": "eslint main.js preload.js src/app.js src/setup.js --fix",
    "format": "prettier --write main.js preload.js src/app.js src/setup.js src/styles.css"
  },
  "keywords": [
    "electron",
    "image",
    "ai",
    "midjourney",
    "openai"
  ],
  "author": "Antony Morrison",
  "license": "MIT",
  "devDependencies": {
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.0.1",
    "jest": "^29.7.0",
    "prettier": "^3.2.5"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/validators.js",
      "src/migrateStore.js",
      "src/logger.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    },
    "moduleNameMapper": {
      "^electron$": "<rootDir>/tests/__mocks__/electron.js",
      "^electron-store$": "<rootDir>/tests/__mocks__/electron-store.js",
      "^electron-updater$": "<rootDir>/tests/__mocks__/electron-updater.js"
    }
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.7"
  },
  "build": {
    "appId": "com.imagedescgen.app",
    "productName": "Image Description Generator",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "main/**/*",
      "ipc/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "publish": {
      "provider": "generic",
      "url": "https://your-update-server.com"
    }
  }
}